# ⚠️ 警告：此檔案含有刻意嵌入的假機密，用於展示 GHAzDO Secret Scanning 功能。
# .env.example 通常保留在版本控制中作為範本，GHAzDO Secret Scanning 會掃描此類檔案。
# 以下機密均為虛假值，不具任何實際效力，僅用於觸發 Secret Scanning 偵測。

# Flask settings
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-me-in-production

# Secret #3 — Stripe Secret Key (Test Mode)
# Format: sk_test_ prefix + alphanumeric string matching 'stripe_api_key'
# DEMO WORST PRACTICE: payment API key committed to .env.example in version control.
STRIPE_SECRET_KEY=sk_test_51AbCdEfGhIjKlMnOpQrStUvWxYz0123456789abcdefghij

# Application settings
LOG_LEVEL=info
APP_PORT=5000
